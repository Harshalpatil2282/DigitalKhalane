# Server Port
PORT=5000

# MongoDB Connection String
# Local: mongodb://localhost:27017/digitalkhalane
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/digitalkhalane
MONGO_URI=mongodb://localhost:27017/digitalkhalane

# JWT Secret Key (Use a long random string in production)
JWT_SECRET=khalane_yatra_utsav_secret_2024_harshal_patil

# JWT Expires In
JWT_EXPIRES_IN=7d

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
